---
// Marquee.astro
---

<section class="relative w-full py-12 sm:py-16 md:py-24 bg-[#07070a] text-white overflow-hidden flex flex-col justify-center items-center border-y border-white/10">
  
  <!-- Row 1 moving left -->
  <div class="whitespace-nowrap flex marquee-left items-center w-max">
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16">Pure Cinema</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16">Pure Cinema</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16">Pure Cinema</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
  </div>

  <!-- Row 2 moving right -->
  <div class="whitespace-nowrap flex marquee-right items-center w-max mt-3 sm:mt-4 transform -translate-x-[8%] sm:-translate-x-[15%]">
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16">Pure Cinema</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16">Pure Cinema</h2>
    <h2 class="font-serif text-[clamp(1.75rem,7vw,6rem)] md:text-[6vw] leading-none uppercase tracking-tighter mr-8 sm:mr-12 md:mr-16 text-transparent [-webkit-text-stroke:1.5px_#E23D28] sm:[-webkit-text-stroke:2px_#E23D28] font-light">No Algorithms</h2>
  </div>

</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    gsap.to(".marquee-left", {
      xPercent: -15,
      ease: "none",
      scrollTrigger: {
        trigger: ".marquee-left",
        start: "top bottom",
        end: "bottom top",
        scrub: 1
      }
    });

    gsap.to(".marquee-right", {
      xPercent: 5,
      ease: "none",
      scrollTrigger: {
        trigger: ".marquee-right",
        start: "top bottom",
        end: "bottom top",
        scrub: 1
      }
    });
  }
</script>
