---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "LUMINA | The Unseen Cinema" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Navbar / Header overlay -->
    <header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 border-b border-transparent px-8 py-6 text-[#efefef] grid grid-cols-2 md:grid-cols-3 items-center">
      <!-- Logo -->
      <div class="flex items-center gap-3 cursor-pointer group">
        <div class="relative w-6 h-6 rounded-full border-[1.5px] border-white flex items-center justify-center overflow-hidden transition-transform duration-500 group-hover:scale-110">
          <div class="w-full h-[1.5px] bg-white absolute"></div>
          <div class="w-2 h-2 bg-[#E23D28] rounded-full absolute right-0"></div>
        </div>
        <span class="font-serif text-xl leading-none tracking-[0.15em] uppercase">Lumina</span>
      </div>
      
      <!-- Nav Links -->
      <nav class="hidden md:flex gap-10 uppercase font-mono text-[11px] tracking-[0.2em] justify-center">
        <a href="#curation-section" class="hover:text-[#E23D28] transition-colors duration-300">Catalog</a>
        <a href="#featured-section" class="hover:text-[#E23D28] transition-colors duration-300">Originals</a>
      </nav>
      
      <!-- Action -->
      <div class="flex justify-end">
        <button class="uppercase border border-white/30 bg-black/20 backdrop-blur-sm px-6 py-2 hover:bg-[#E23D28] hover:border-[#E23D28] transition-colors duration-300 font-mono text-[11px] tracking-[0.2em] text-white">
          Sign In
        </button>
      </div>
    </header>

    <main id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </main>

    <script src="../scripts/gl-scroll.ts"></script>
    <script>
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (nav) {
          if (window.scrollY > 50) {
            nav.classList.add('bg-[#07070a]/90', 'backdrop-blur-md', 'border-white/10', 'py-4');
            nav.classList.remove('py-6', 'border-transparent');
          } else {
            nav.classList.remove('bg-[#07070a]/90', 'backdrop-blur-md', 'border-white/10', 'py-4');
            nav.classList.add('py-6', 'border-transparent');
          }
        }
      });
    </script>
  </body>
</html>
